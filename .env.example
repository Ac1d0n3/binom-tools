APP_NAME="Binom Governance"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/binom-tools

# Asset URLs: `npm run build` emits relative font paths — same build for local MAMP and production.
# APP_URL only affects Laravel routes + @vite entry URLs at runtime (not the build itself).

BINOM_WEBSITE_URL=https://binom.net
BINOM_TOOLS_REPO_URL=https://github.com/Ac1d0n3/binom-tools

# Displayed in footer and tools overview (not npm semver)
# BINOM_TOOLS_VERSION=0.1.0
# BINOM_TOOLS_BETA=true

# Optional: private Markdown stories outside this repository
# BINOM_TOOLS_CONTENT_PATH=/path/to/private-governance-content

# Optional file-based accounts (no DB). Passwords stored only as password_hash digests.
# BINOM_TOOLS_ACCOUNTS_ENABLED=false
# BINOM_TOOLS_ACCOUNTS_PATH=
# When accounts are enabled, prefer file sessions (no DB session table):
# SESSION_DRIVER=file

# Playbook series pager: both | series | global
# PLAYBOOKS_SERIES_PAGER=both

# Share button on story pages (Web Share / copy link)
# PLAYBOOKS_SHARE_ENABLED=true

# Story overview (/playbooks) — page title & lead (default: hidden)
# PLAYBOOKS_OVERVIEW_SHOW_TITLE=true
# PLAYBOOKS_OVERVIEW_SHOW_LEAD=true
# PLAYBOOKS_OVERVIEW_TITLE_DE=Stories
# PLAYBOOKS_OVERVIEW_TITLE_EN=Stories
# PLAYBOOKS_OVERVIEW_LEAD_DE=Schritt-für-Schritt-Governance-Guides …
# PLAYBOOKS_OVERVIEW_LEAD_EN=Step-by-step governance guides …

# Governance overview (/tools) — page title & lead (default: hidden)
# TOOLS_OVERVIEW_SHOW_TITLE=true
# TOOLS_OVERVIEW_SHOW_LEAD=true
# TOOLS_OVERVIEW_TITLE_DE=Governance
# TOOLS_OVERVIEW_TITLE_EN=Governance
# TOOLS_OVERVIEW_LEAD_DE=Interaktive Referenz-Workflows …
# TOOLS_OVERVIEW_LEAD_EN=Interactive reference workflows …

# Per-tool toggles (default true). false hides nav/overview and returns 404.
# TOOL_DBT_GOVERNANCE_MACRO_GENERATOR_ENABLED=true
# TOOL_PII_POLICY_GENERATOR_ENABLED=true
# TOOL_PII_UNREVIEWED_GATE_GENERATOR_ENABLED=true
# TOOL_PII_RECOMMEND_GENERATOR_ENABLED=true
# TOOL_DBT_DQ_MACRO_GENERATOR_ENABLED=true
# TOOL_DBT_DQ_RULES_GENERATOR_ENABLED=true
# TOOL_DBT_DQ_HISTORY_GENERATOR_ENABLED=true
# TOOL_SCHEMA_YML_EDITOR_ENABLED=true
# TOOL_PROMPT_STUDIO_ENABLED=true
# TOOL_GOVERNANCE_AI_SANITIZER_ENABLED=true

# Optional per-tool login (only when BINOM_TOOLS_ACCOUNTS_ENABLED=true). Default: open.
# TOOL_PROMPT_STUDIO_LOGIN_REQUIRED=false
# TOOL_GOVERNANCE_AI_SANITIZER_LOGIN_REQUIRED=false
# TOOL_DBT_GOVERNANCE_MACRO_GENERATOR_LOGIN_REQUIRED=false
# TOOL_PII_POLICY_GENERATOR_LOGIN_REQUIRED=false
# TOOL_PII_UNREVIEWED_GATE_GENERATOR_LOGIN_REQUIRED=false
# TOOL_PII_RECOMMEND_GENERATOR_LOGIN_REQUIRED=false
# TOOL_DBT_DQ_MACRO_GENERATOR_LOGIN_REQUIRED=false
# TOOL_DBT_DQ_RULES_GENERATOR_LOGIN_REQUIRED=false
# TOOL_DBT_DQ_HISTORY_GENERATOR_LOGIN_REQUIRED=false
# TOOL_SCHEMA_YML_EDITOR_LOGIN_REQUIRED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
